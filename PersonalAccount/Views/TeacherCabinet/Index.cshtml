@model TeacherCabinetViewModel

<div class="container d-flex flex-column align-items-stretch gap-5">
    <partial model="@(new CabinetViewModel
                    {
                        Email = Model.Email,
                        FullName = Model.FullName,
                        PhotoUrl = Model.PhotoUrl,
                        IsEmailConfirmed = Model.IsEmailConfirmed,
                        Title = "Личный кабинет преподавателя",
                    })"
             name="_CabinetPersonalInfo"/>

    <div class="d-flex flex-column align-items-stretch gap-3">
        @foreach (var (discipline, groups) in Model.GroupsByDisciplines)
        {
            <div class="d-flex flex-column align-items-stretch gap-2">
                <h2 class="text-start fw-bold text-primary">@discipline.Name</h2>
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var group in groups)
                    {
                        <div class="card d-flex align-items-stretch justify-content-center" style="width: 200px; height: 100px; background-image: url(@group.ImageUrl); background-size: cover; background-color: #2b2f32">
                            <div class="card-body d-flex text-white align-items-center justify-content-center">
                                <span class="text-center">@group.Name</span>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>
